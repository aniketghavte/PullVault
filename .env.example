####################################################
# PullVault — Environment Variables
# Copy this to `.env` (root) and adjust values.
# Each app reads from the root via dotenv-cli or its
# own loader. NEVER commit a real `.env`.
####################################################

# ---- Supabase (Postgres + Auth) ----
# From your Supabase project: Settings -> API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...                 # client-safe (RLS enforced)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...         # server-only, bypasses RLS

# Postgres connection (Supabase -> Settings -> Database -> Connection string)
# Use the *pooler* URL for app traffic, *direct* URL for migrations.
DATABASE_URL=postgresql://postgres:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# ---- Upstash Redis (cache + pub/sub + BullMQ) ----
# Use the *Redis URL* form (rediss://) for BullMQ. The REST API
# vars are only needed if you also call Upstash from edge functions.
REDIS_URL=rediss://default:PASSWORD@YOUR-ENDPOINT.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://YOUR-ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# ---- Catalog / price refresh (apps/realtime; cuts Redis / Upstash command volume) ----
# Hot = simulated price drift; full = Pokemon TCG API catalog sync. BullMQ repeats add many commands.
# Defaults below are dev-friendly. For production, shorten intervals and/or raise samples as needed.
CATALOG_AUTOSEED=false
PRICE_REFRESH_HOT_INTERVAL_MS=900000
PRICE_REFRESH_FULL_INTERVAL_MS=2592000000
PRICE_REFRESH_HOT_SAMPLE=4
PRICE_REFRESH_FULL_PAGES=1

# ---- Realtime server ----
REALTIME_PORT=4000
REALTIME_PUBLIC_URL=http://localhost:4000        # what the browser connects to
REALTIME_INTERNAL_TOKEN=change-me-long-random    # web -> realtime trusted calls

# ---- Web app ----
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
NEXT_PUBLIC_REALTIME_URL=${REALTIME_PUBLIC_URL}
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Card data providers ----
# Free, no auth required.
POKEMON_TCG_API_URL=https://api.pokemontcg.io/v2
POKEMON_TCG_API_KEY=                              # optional, raises rate limit

# TCGPlayer — fill in if/when approved. Otherwise we fall back to
# Pokemon TCG API + simulated price walks (see architecture.md).
TCGPLAYER_PUBLIC_KEY=
TCGPLAYER_PRIVATE_KEY=

# ---- App config ----
NODE_ENV=development
LOG_LEVEL=debug
DEFAULT_STARTING_BALANCE_USD=500

# ---- Admin endpoints ----
# Used by POST /api/admin/refresh-drops to seed fresh drops before a session.
# Generate a random string and set the same value in Vercel env vars.
ADMIN_SECRET=change-me-random-string
